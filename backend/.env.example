# ============================================================
# Travel Planner - Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# MongoDB connection string
MONGO_URI=mongodb://username:password@host:27017/?authSource=dbname

# MongoDB database name
DB_NAME=your_database_name

# JWT signing secret — generate with:
#   node -e "require('crypto').randomBytes(64).toString('hex')|Write-Host"
# Must be at least 32 characters. Use 64+ bytes (128 hex chars) in production.
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET_MIN_32_CHARS

# Server port
PORT=5000

# Gin mode: "debug" for development, "release" for production
GIN_MODE=release

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000

# ── Production Tuning ────────────────────────────────────────

# MongoDB connection pool size
MONGO_MAX_POOL_SIZE=200
MONGO_MIN_POOL_SIZE=20

# Rate limiter: max requests per second per IP
RATE_LIMIT_RPS=100

# Request timeout in seconds
REQUEST_TIMEOUT_SECONDS=30

# Structured log level: trace, debug, info, warn, error, fatal, panic
LOG_LEVEL=info
